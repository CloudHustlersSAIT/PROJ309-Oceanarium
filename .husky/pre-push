#!/usr/bin/env sh

cd frontend && npm run lint:check && npm run test || exit 1

cd ../backend
if [ -f "./venv/bin/python" ]; then
  PYTHON="./venv/bin/python"
elif [ -f "./venv/Scripts/python.exe" ]; then
  PYTHON="./venv/Scripts/python.exe"
else
  echo "Python venv not found in backend/venv"
  exit 1
fi
$PYTHON -m ruff check app/ && $PYTHON -m ruff format --check app/ && $PYTHON -m pytest tests/ --tb=short -q

 
